TELEGRAM_TOKEN = "8738159038:AAGReqoOG7pdbCZaVMruq97zpkezoJrUmBw"
CHAT_ID = "8639724254import requests
import pandas as pd
import numpy as np
import ta
from datetime import datetime

# ------------------------
# CONFIG
# ------------------------

TELEGRAM_TOKEN = "TON_TOKEN_ICI"
CHAT_ID = "TON_CHAT_ID_ICI"

# ------------------------
# GET BTC PRICE DATA
# ------------------------

def get_btc_data():
    url = "https://api.binance.com/api/v3/klines"
    params = {
        "symbol": "BTCUSDT",
        "interval": "1w",
        "limit": 500
    }
    response = requests.get(url, params=params)
    data = response.json()
    
    df = pd.DataFrame(data, columns=[
        "time","open","high","low","close","volume",
        "_","_","_","_","_","_"
    ])
    
    df["close"] = df["close"].astype(float)
    df["time"] = pd.to_datetime(df["time"], unit='ms')
    return df

# ------------------------
# FEAR & GREED
# ------------------------

def get_fear_greed():
    url = "https://api.alternative.me/fng/"
    response = requests.get(url)
    data = response.json()
    return int(data["data"][0]["value"])

# ------------------------
# ANALYSIS
# ------------------------

def analyze_market():
    df = get_btc_data()
    
    current_price = df["close"].iloc[-1]
    ath = df["close"].max()
    
    # MA200W
    df["ma200"] = df["close"].rolling(window=200).mean()
    ma200 = df["ma200"].iloc[-1]
    
    # RSI
    rsi = ta.momentum.RSIIndicator(df["close"], window=14).rsi().iloc[-1]
    
    fear_greed = get_fear_greed()
    
    phase = ""
    action = ""
    
    if current_price < ma200:
        phase = "🐻 Bear profond"
        action = "Renforcer DCA"
    elif rsi > 75 and fear_greed > 80:
        phase = "🚀 Euphorie"
        action = "Prendre profits 20%"
    elif current_price > ath * 0.95:
        phase = "📈 Bull confirmé"
        action = "Surveiller et alléger progressivement"
    else:
        phase = "🧊 Accumulation / Transition"
        action = "DCA normal"
    
    message = f"""
📊 BTC Market Update ({datetime.now().date()})

Prix: {round(current_price,2)}$
ATH: {round(ath,2)}$
MA200W: {round(ma200,2)}$
RSI: {round(rsi,2)}
Fear & Greed: {fear_greed}

Phase: {phase}
Action recommandée: {action}
"""
    
    return message

# ------------------------
# TELEGRAM ALERT
# ------------------------

def send_telegram(message):
    url = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage"
    payload = {
        "chat_id": CHAT_ID,
        "text": message
    }
    requests.post(url, data=payload)

# ------------------------
# RUN
# ------------------------

if __name__ == "__main__":
    msg = analyze_market()
    print(msg)
    send_telegram(msg)
